# ===== 서버 =====
PORT=3000
# 대시보드 접근 보호용 비밀번호 (비워두면 인증 없음 — 클라우드 배포 시 반드시 설정 권장)
APP_PASSWORD=

# ===== 자격증명 암호화 키 =====
# 숲나들e 로그인 정보를 DB에 저장할 때 암호화하는 키. 임의의 긴 문자열로 설정.
# 비워두면 기동 시 자동 생성되어 data/secret.key 에 저장됩니다(분실 시 저장된 자격증명 복호화 불가).
ENCRYPTION_KEY=

# ===== 텔레그램 알림 =====
# @BotFather 로 봇 생성 후 받은 토큰
TELEGRAM_BOT_TOKEN=
# 알림을 받을 chat id. @userinfobot 에게 말 걸면 확인 가능. 여러 명이면 콤마로 구분.
TELEGRAM_CHAT_ID=

# ===== Playwright =====
# 디버깅 시 브라우저 창을 띄우려면 false (서버/클라우드에서는 true 권장)
HEADLESS=true
# 빈자리 미발견 시에도 결과 HTML/스크린샷을 debug/ 에 저장 (문제 진단용)
DEBUG_DUMP=false
